{
  "$schema": "https://developer.microsoft.com/json-schemas/fabric/item/report/definition/visualContainer/2.10.0/schema.json",
  "name": "visual005",
  "position": {
    "x": 20,
    "y": 150,
    "z": 5000,
    "height": 280,
    "width": 620,
    "tabOrder": 5000
  },
  "visual": {
    "visualType": "columnChart",
    "query": {
      "queryState": {
        "Category": {
          "projections": [
            {
              "field": {
                "Column": {
                  "Expression": {
                    "SourceRef": {
                      "Entity": "migration_artifacts"
                    }
                  },
                  "Property": "wave"
                }
              },
              "queryRef": "migration_artifacts.wave",
              "nativeQueryRef": "wave",
              "active": true
            }
          ]
        },
        "Series": {
          "projections": [
            {
              "field": {
                "Column": {
                  "Expression": {
                    "SourceRef": {
                      "Entity": "migration_artifacts"
                    }
                  },
                  "Property": "status"
                }
              },
              "queryRef": "migration_artifacts.status",
              "nativeQueryRef": "status"
            }
          ]
        },
        "Y": {
          "projections": [
            {
              "field": {
                "Measure": {
                  "Expression": {
                    "SourceRef": {
                      "Entity": "_Measures"
                    }
                  },
                  "Property": "Total Artifacts"
                }
              },
              "queryRef": "_Measures.Total Artifacts",
              "nativeQueryRef": "Total Artifacts"
            }
          ]
        }
      }
    },
    "visualContainerObjects": {
      "title": [
        {
          "properties": {
            "text": {
              "expr": {
                "Literal": {
                  "Value": "'Wave Progress by Status'"
                }
              }
            },
            "show": {
              "expr": {
                "Literal": {
                  "Value": "true"
                }
              }
            }
          }
        }
      ]
    },
    "drillFilterOtherVisuals": true
  }
}