                  "Property": "artifact_name"
                }
              },
              "queryRef": "migration_artifacts.artifact_name",
              "nativeQueryRef": "artifact_name"
            }
          ]
        },
        "Series": {
          "projections": [
            {
              "field": {
                "Column": {
                  "Expression": {
                    "SourceRef": {
                      "Entity": "migration_artifacts"
                    }
                  },
                  "Property": "complexity"
                }
              },
              "queryRef": "migration_artifacts.complexity",
              "nativeQueryRef": "complexity"
            }
          ]
        },
        "X": {
          "projections": [
            {
              "field": {
