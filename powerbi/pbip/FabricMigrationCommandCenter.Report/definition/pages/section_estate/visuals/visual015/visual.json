              },
              "queryRef": "migration_artifacts.domain",
              "nativeQueryRef": "domain",
              "active": true
            }
          ]
        },
        "Series": {
          "projections": [
            {
              "field": {
                "Column": {
                  "Expression": {
                    "SourceRef": {
                      "Entity": "migration_artifacts"
                    }
                  },
                  "Property": "complexity"
                }
              },
              "queryRef": "migration_artifacts.complexity",
              "nativeQueryRef": "complexity"
            }
          ]
        },
        "Y": {
          "projections": [
            {
              "field": {
                "Measure": {
                  "Expression": {
                    "SourceRef": {
                      "Entity": "_Measures"
                    }
                  },
                  "Property": "Total Artifacts"
                }
              },
              "queryRef": "_Measures.Total Artifacts",
              "nativeQueryRef": "Total Artifacts"
            }
          ]
        }
      }
    },
    "visualContainerObjects": {
      "title": [
        {
          "properties": {
            "text": {
              "expr": {
                "Literal": {
                  "Value": "'Complexity Mix by Business Domain'"
                }
              }
            },
            "show": {
              "expr": {
                "Literal": {
                  "Value": "true"
                }
              }
            }
